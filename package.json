{
  "name": "@motif-ui/react",
  "version": "0.0.4",
  "description": "A React UI library created by public sector developers",
  "author": "MOTIF UI | Turksat e-Government Application Development",
  "homepage": "https://github.com/motif-ui/motifreact#readme",
  "bugs": {
    "url": "https://github.com/motif-ui/motifreact/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motif-ui/motifreact.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev --webpack",
    "start": "next start",
    "test": "jest --watch",
    "test:update": "npm run test:ci -- -u",
    "test:ci": "jest --ci",
    "build:lib": "rollup -c",
    "build:storybook": "storybook build --stats-json",
    "build:tokens": "node src/scripts/buildToken",
    "build:theme": "node src/scripts/buildTheme",
    "build:theme-default": "npm run build:theme src/lib/styles/tokens/design-tokens.tokens.json default-theme src/lib/styles/themes",
    "lint": "eslint",
    "lint:staged": "eslint --cache",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "type-check": "tsc --noemit",
    "maintanence-check": "npm run lint && npm run type-check && npm run test:ci && npm run build:lib && npm run build:theme-default && npm run build && npm run dev"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.1",
    "@eslint/js": "^9.39.2",
    "@rollup-extras/plugin-copy": "1.11.1",
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "12.3.0",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/addon-links": "10.2.8",
    "@storybook/nextjs": "10.2.8",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "browserslist": "^4.28.0",
    "chromatic": "15.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "30.2.0",
    "lint-staged": "16.2.7",
    "next": "^16.1.1",
    "postcss-url": "10.1.3",
    "prettier": "^3.7.4",
    "rollup": "4.57.1",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-dts": "6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-styler": "^2.0.0",
    "sass": "1.97.3",
    "storybook": "10.2.8",
    "style-dictionary": "5.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.50.1",
    "use-deep-compare-effect": "^1.8.1"
  },
  "peerDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.es.js",
      "require": "./dist/hooks.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.es.js",
      "require": "./dist/types.cjs"
    },
    "./themes/*": "./dist/themes/*",
    "./*": "./dist/*"
  },
  "keywords": [
    "motif",
    "react",
    "ui",
    "library",
    "component",
    "public",
    "sector",
    "design",
    "token",
    "turksat",
    "e-devlet",
    "turkiye",
    "gov"
  ]
}
